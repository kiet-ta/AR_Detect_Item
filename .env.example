# Magic Doodle — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- Firebase (Dev) ---
FIREBASE_PROJECT_ID_DEV=magic-doodle-dev
FIREBASE_STORAGE_BUCKET_DEV=magic-doodle-dev.appspot.com
FIREBASE_API_KEY_DEV=YOUR_DEV_API_KEY_HERE

# --- Firebase (Staging) ---
FIREBASE_PROJECT_ID_STAGING=magic-doodle-staging
FIREBASE_STORAGE_BUCKET_STAGING=magic-doodle-staging.appspot.com
FIREBASE_API_KEY_STAGING=YOUR_STAGING_API_KEY_HERE

# --- Firebase (Production) ---
FIREBASE_PROJECT_ID_PROD=magic-doodle-prod
FIREBASE_STORAGE_BUCKET_PROD=magic-doodle-prod.appspot.com
FIREBASE_API_KEY_PROD=YOUR_PROD_API_KEY_HERE

# --- ML Model ---
TFLITE_MODEL_VERSION=1.0.0
TFLITE_MODEL_FILENAME=quickdraw_classifier_v1.tflite
CONFIDENCE_THRESHOLD=0.70
DATA_FLYWHEEL_THRESHOLD=0.50

# --- App Config ---
SCREEN_TIME_LIMIT_MINUTES=20
SESSION_SYNC_INTERVAL_SECONDS=30
MAX_FAILED_DRAWINGS_QUEUE=50
