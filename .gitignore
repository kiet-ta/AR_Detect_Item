# ========================================
# TFLite Models (large binary files)
# ========================================
# Exclude pre-trained models from repo.
# Download from Firebase Storage on first launch.
assets/ml_models/*.tflite
assets/ml_models/*.lite

# ========================================
# 3D Assets (large binary files)
# ========================================
# Exclude 3D models from repo.
# Download from Firebase Storage on demand.
assets/models_3d/*.glb
assets/models_3d/*.gltf
assets/models_3d/*.bin
assets/models_3d/*.obj
assets/models_3d/*.fbx
assets/models_3d/*.usdz

# ========================================
# Audio Assets (optional, depending on size)
# ========================================
# Uncomment if audio files exceed 1MB each:
# assets/audio/*.mp3
# assets/audio/*.aac
# assets/audio/*.wav
# assets/audio/*.m4a

# Keep small audio assets in repo (< 100KB)
!assets/audio/sfx_*.mp3

# ========================================
# Image Assets (keep small UI images)
# ========================================
# Exclude large image sets
assets/images/raw/
assets/images/*.psd
assets/images/*.ai

# ========================================
# Temporary Files
# ========================================
*.tmp
*.temp
*.bak
*.orig
.flutter-plugins-dependencies.bak

# ========================================
# Project-Specific (Magic Doodle)
# ========================================
# Data Flywheel failed drawings (local cache)
cache/
failed_drawings/

# Usage logs (before sync to Firebase)
usage_logs.json

# Development mock data
mocks/
fixtures/large_*.json
